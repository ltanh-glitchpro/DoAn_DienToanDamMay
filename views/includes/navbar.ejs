<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Bootstrap CSS CDN -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-ENjdO4Dr2bkBIFxQpeoBkx1ypCFf4sFzEYv5P3ysF1hK/h/LMwNLD69Npy4HI+N9"
      crossorigin="anonymous"
    />

    <!-- Biểu tượng Bootstrap Icons -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
      rel="stylesheet"
    />

    <!-- CSS Navbar riêng -->
    <link rel="stylesheet" href="/css/navbar.css" />

    <title>KATEE</title>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-info" id="nav">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">
          <img
            src="/images/logow1.svg"
            alt="Logo"
            width="30"
            height="30"
            class="d-inline-block align-text-top"
          />
          KATEE
        </a>

        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-lg-center">
            <li class="nav-item">
              <a class="nav-link active" href="/tinmoinhat">
                <i class="bi bi-compass"></i> Top tuần
              </a>
            </li>

            <li class="nav-item dropdown hover-dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="bi bi-card-list"></i> Danh sách truyện
              </a>
              <ul class="dropdown-menu dropdown-scroll">
                <% if (navNovels && navNovels.length) { %>
                  <% navNovels.forEach(function(item) { %>
                    <li>
                      <a class="dropdown-item text-truncate" href="/novel/chitiet/<%= item._id %>">
                        <%= item.TieuDe %>
                      </a>
                    </li>
                  <% }); %>
                <% } else { %>
                  <li><span class="dropdown-item-text text-muted">Chưa có truyện</span></li>
                <% } %>
              </ul>
            </li>

            <li class="nav-item dropdown hover-dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="bi bi-tags"></i> Thể loại
              </a>
              <ul class="dropdown-menu dropdown-scroll">
                <% if (navTheLoai && navTheLoai.length) { %>
                  <% navTheLoai.forEach(function(item) { %>
                    <li>
                      <a class="dropdown-item" href="/loc/<%= item._id %>">
                        <%= item.tentheloai %>
                      </a>
                    </li>
                  <% }); %>
                <% } else { %>
                  <li><span class="dropdown-item-text text-muted">Chưa có thể loại</span></li>
                <% } %>
              </ul>
            </li>

            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="bi bi-gear"></i> Tùy chỉnh
              </a>
              <div class="dropdown-menu theme-menu dropdown-menu-end">
                <div class="theme-control-row">
                  <span class="theme-control-label">Màu nền</span>
                  <label class="theme-switch" for="themeToggleInput" title="Bật hoặc tắt nền tối">
                    <input type="checkbox" id="themeToggleInput" />
                    <span class="theme-slider"></span>
                  </label>
                </div>
              </div>
            </li>

            <% if(typeof session !== "undefined" && session.MaNguoiDung) { %>
            <% if(session.QuyenHan === "admin") { %>
            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle"
                href="#"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false"
              >
                <i class="bi bi-gear"></i> Quản lý
              </a>
              <ul class="dropdown-menu">
                <li>
                  <a class="dropdown-item" href="/theloai">
                    <i class="bi bi-card-checklist"></i> Thể loại
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/taikhoan">
                    <i class="bi bi-people"></i> Tài khoản
                  </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                  <a class="dropdown-item" href="/novel">
                    <i class="bi bi-file-earmark-richtext"></i> Truyện
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="/chuong">
                    <i class="bi bi-file-earmark-richtext"></i> Chương
                  </a>
                </li>
              </ul>
            </li>
            <% } %>
            <% } %>
          </ul>

          <div class="d-flex align-items-center gap-2 ms-lg-auto navbar-right-wrap">
            <form action="/timkiem" class="d-flex search-form" role="search" autocomplete="off">
              <input
                class="form-control me-2 search-input"
                type="search"
                name="tukhoa"
                id="searchNovelInput"
                placeholder="Tên truyện bạn tìm?"
              />
              <button class="btn btn-outline-success" type="submit">
                <i class="bi bi-search"></i>
              </button>
              <ul id="searchSuggestionList" class="search-suggestion-list d-none"></ul>
            </form>

            <% if(typeof session === "undefined" || !session.MaNguoiDung) { %>
            <div class="d-flex align-items-center gap-2 auth-links">
              <a class="nav-link" href="/auth/dangnhap">
                <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
              </a>
              <a class="nav-link" href="/auth/dangky">
                <i class="bi bi-person-plus-fill"></i> Đăng ký
              </a>
            </div>
            <% } else { %>
            <ul class="navbar-nav mb-2 mb-lg-0 align-items-lg-center">
              <li class="nav-item dropdown">
                <a
                  class="nav-link dropdown-toggle"
                  href="#"
                  role="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false"
                >
                  <i class="bi bi-person"></i> <%= session.HoVaTen %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li>
                    <a class="dropdown-item" href="/novel/them">
                      <i class="bi bi-file-earmark-plus"></i> Đăng truyện
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="/novel/cuatoi">
                      <i class="bi bi-journal-bookmark"></i> Truyện của tôi
                    </a>
                  </li>
                  <li>
                    <a class="dropdown-item" href="/chuong/cuatoi">
                      <i class="bi bi-journal-bookmark"></i> Chương truyện của tôi
                    </a>
                  </li>
                  <li><hr class="dropdown-divider" /></li>
                  <li>
                    <a
                      class="dropdown-item"
                      href="/taikhoan/hoso/<%= session.MaNguoiDung %>"
                    >
                      <i class="bi bi-person-badge"></i> Hồ sơ cá nhân
                    </a>
                  </li>
                </ul>
              </li>

              <li class="nav-item">
                <a class="nav-link js-logout-link" href="/auth/dangxuat">
                  <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
              </li>
            </ul>
            <% } %>
          </div>
        </div>
      </div>
    </nav>

    <% if (breadcrumbs && breadcrumbs.length) { %>
    <div class="breadcrumb-bar">
      <div class="breadcrumb-wrap">
        <% breadcrumbs.forEach(function(crumb, index) { %>
          <% if (index > 0) { %>
            <span class="breadcrumb-sep">/</span>
          <% } %>

          <% if (crumb.url) { %>
            <a class="breadcrumb-link" href="<%= crumb.url %>"><%= crumb.label %></a>
          <% } else { %>
            <span class="breadcrumb-current"><%= crumb.label %></span>
          <% } %>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Bootstrap JS và Popper.js CDN -->
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
      integrity="sha384-zDaPzD6M9ApeRbdogX5HzvT9LT5fV/yozLBVkXx+1BhEdEex64lZT+4/pZBT+Qtw"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"
      integrity="sha384-QF03FxQZrG7mj7a7JQ+1JK4gWh0zAlK6jJXtv0YZbIaxVXMJRzNBBVsFm7u1WPa5"
      crossorigin="anonymous"
    ></script>
    <script>
      (function () {
        var input = document.getElementById("searchNovelInput");
        var list = document.getElementById("searchSuggestionList");
        if (!input || !list) return;

        var debounceTimer;
        var activeIndex = -1;

        function hideList() {
          list.classList.add("d-none");
          list.innerHTML = "";
          activeIndex = -1;
        }

        function renderItems(items) {
          if (!items.length) {
            hideList();
            return;
          }

          list.innerHTML = items
            .map(function (item) {
              var imgSrc = item.HinhAnh || "/images/logow1.svg";
              return (
                '<li class="search-suggestion-item">' +
                '<a href="/novel/chitiet/' +
                item._id +
                '" class="search-suggestion-link">' +
                '<img src="' +
                imgSrc +
                '" alt="' +
                item.TieuDe +
                '" class="search-suggestion-thumb" />' +
                '<span class="search-suggestion-title">' +
                item.TieuDe +
                '</span>' +
                "</a>" +
                "</li>"
              );
            })
            .join("");

          list.classList.remove("d-none");
          activeIndex = -1;
        }

        function loadSuggestions() {
          var keyword = input.value.trim();

          if (!keyword) {
            hideList();
            return;
          }

          fetch("/timkiem-goiy?tukhoa=" + encodeURIComponent(keyword))
            .then(function (res) {
              return res.json();
            })
            .then(function (data) {
              renderItems(Array.isArray(data) ? data : []);
            })
            .catch(function () {
              hideList();
            });
        }

        function updateActiveItem(step) {
          var items = list.querySelectorAll(".search-suggestion-link");
          if (!items.length) return;

          activeIndex += step;
          if (activeIndex >= items.length) activeIndex = 0;
          if (activeIndex < 0) activeIndex = items.length - 1;

          items.forEach(function (el) {
            el.classList.remove("active");
          });

          items[activeIndex].classList.add("active");
        }

        input.addEventListener("input", function () {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(loadSuggestions, 200);
        });

        input.addEventListener("keydown", function (event) {
          if (list.classList.contains("d-none")) return;

          if (event.key === "ArrowDown") {
            event.preventDefault();
            updateActiveItem(1);
          } else if (event.key === "ArrowUp") {
            event.preventDefault();
            updateActiveItem(-1);
          } else if (event.key === "Enter") {
            var active = list.querySelector(".search-suggestion-link.active");
            if (active) {
              event.preventDefault();
              window.location.href = active.getAttribute("href");
            }
          } else if (event.key === "Escape") {
            hideList();
          }
        });

        document.addEventListener("click", function (event) {
          if (!event.target.closest(".search-form")) {
            hideList();
          }
        });

        var logoutLinks = document.querySelectorAll(".js-logout-link");
        logoutLinks.forEach(function (link) {
          link.addEventListener("click", function (event) {
            var shouldLogout = window.confirm("Bạn có muốn đăng xuất không?");
            if (!shouldLogout) {
              event.preventDefault();
            }
          });
        });
      })();
    </script>
  </body>
</html>
