<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <style>
    .chapter-page-wrap {
      margin-top: 16px;
      background: #fff;
      border-radius: 12px;
      border: 1px solid #e8edf3;
      box-shadow: 0 6px 16px rgba(10, 31, 64, 0.06);
      overflow: hidden;
    }

    .chapter-page-title {
      font-size: 1.2rem;
      font-weight: 800;
      color: #1f365c;
      letter-spacing: 0.2px;
      text-transform: uppercase;
      margin: 0;
      padding: 16px 18px;
      border-bottom: 1px solid #edf2f8;
      background: #f7fafc;
    }

    .chapter-row-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .chapter-row {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 10px 16px;
      border-bottom: 1px solid #edf2f8;
      transition: background-color 0.2s ease;
    }

    .chapter-row-link:hover .chapter-row {
      background: #f9fcff;
    }

    .chapter-row:last-child {
      border-bottom: none;
    }

    .chapter-cover {
      width: 168px;
      height: 92px;
      object-fit: cover;
      border-radius: 6px;
      border: 1px solid #dde7f3;
      flex-shrink: 0;
      background: #eef3f8;
    }

    .chapter-main {
      min-width: 0;
      flex: 1;
    }

    .chapter-title {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
      color: #26374d;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .title-icon {
      font-size: 0.85rem;
      color: #495057;
      opacity: 0.85;
      flex-shrink: 0;
    }

    .chapter-meta {
      margin-top: 4px;
      display: flex;
      align-items: center;
      gap: 8px;
      color: #65758a;
      font-size: 0.95rem;
    }

    .chapter-author {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }

    .meta-badge {
      font-size: 0.76rem;
      border: 1px solid;
      border-radius: 2px;
      padding: 0 4px;
      line-height: 1.3;
      font-weight: 600;
    }

    .meta-badge.new {
      border-color: #87aef5;
      color: #5f8fe8;
      background: #f2f6ff;
    }

    .meta-badge.full {
      border-color: #9cc6a0;
      color: #5c9f61;
      background: #eef8ef;
    }

    .chapter-total {
      flex-shrink: 0;
      min-width: 96px;
      text-align: right;
      font-size: 1rem;
      font-weight: 700;
      color: #5b8bb3;
    }

    .chapter-empty {
      margin: 16px;
      border-radius: 10px;
      border: 1px dashed #d4deea;
      background: #f7fbff;
      color: #5f7188;
      padding: 18px;
      text-align: center;
      font-weight: 500;
    }

    body.theme-dark .chapter-page-wrap {
      background: #1a2533;
      border-color: #2f3e50;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3);
    }

    body.theme-dark .chapter-page-title {
      color: #e8f0fb;
      background: #223245;
      border-color: #2f3e50;
    }

    body.theme-dark .chapter-row {
      border-color: #2f3e50;
    }

    body.theme-dark .chapter-row-link:hover .chapter-row {
      background: #203145;
    }

    body.theme-dark .chapter-cover {
      border-color: #3a4b60;
      background: #243447;
    }

    body.theme-dark .chapter-title {
      color: #e8f0fb;
    }

    body.theme-dark .title-icon,
    body.theme-dark .chapter-meta {
      color: #b5c4d8;
    }

    body.theme-dark .chapter-total {
      color: #95d4ff;
    }

    body.theme-dark .chapter-empty {
      border-color: #37506b;
      background: #1d2f44;
      color: #bfd2e7;
    }

    @media (max-width: 768px) {
      .chapter-row {
        flex-wrap: wrap;
      }

      .chapter-cover {
        width: 128px;
        height: 74px;
      }

      .chapter-total {
        width: 100%;
        text-align: left;
        margin-top: 6px;
      }
    }
  </style>
</head>
<body>
  <div class="container py-3">
    <%- include('includes/navbar') %>

    <section class="chapter-page-wrap">
      <h1 class="chapter-page-title"><%= rangeLabel || title %></h1>

      <% if (novel && novel.length) { %>
        <% novel.forEach(function (item) { %>
          <% const isNew = new Date(item.NgayDang) > new Date(Date.now() - 7 * 24 * 60 * 60 * 1000); %>
          <% const isFull = Number(item.TrangThai) === 1; %>
          <a href="/novel/chitiet/<%= item._id %>" class="chapter-row-link">
            <div class="chapter-row">
              <img src="<%= resolveImageUrl(item.HinhAnh, '/images/uploads', '/images/noimage.png') %>" alt="<%= item.TieuDe %>" class="chapter-cover" onerror="this.onerror=null;this.src='/images/noimage.png';" />

              <div class="chapter-main">
                <h2 class="chapter-title">
                  <i class="bi bi-book title-icon"></i>
                  <span><%= item.TieuDe %></span>
                </h2>
                <div class="chapter-meta">
                  <span class="chapter-author"><i class="bi bi-pen"></i> <%= item.TaiKhoan && item.TaiKhoan.HoVaTen ? item.TaiKhoan.HoVaTen : 'Ẩn danh' %></span>
                  <% if (isNew) { %><span class="meta-badge new">New</span><% } %>
                  <% if (isFull) { %><span class="meta-badge full">Full</span><% } %>
                </div>
              </div>

              <div class="chapter-total">Chương <%= item.SoChuong || 0 %></div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="chapter-empty">
          <i class="bi bi-info-circle me-1"></i>
          <%= emptyMessage || 'Hiện chưa có truyện phù hợp với bộ lọc này.' %>
        </div>
      <% } %>
    </section>

    <%- include('includes/footer') %>
  </div>

  <%- include('includes/javascript') %>
</body>
</html>
