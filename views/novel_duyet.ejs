<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
  <div class="container">
    <%- include('includes/navbar') %>

    <div class="card mt-3 shadow-sm">
      <div class="card-header fw-bold">Duyệt truyện: <%= novel.TieuDe %></div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <img
              src="<%= resolveImageUrl(novel.HinhAnh, '/images/uploads', '/images/noimage.png') %>"
              class="img-fluid rounded border"
              alt="<%= novel.TieuDe %>"
              onerror="this.onerror=null;this.src='/images/noimage.png';"
            />
          </div>
          <div class="col-md-8">
            <h4 class="mb-2"><%= novel.TieuDe %></h4>
            <p class="mb-1"><strong>Tác giả:</strong> <%= novel.TaiKhoan ? novel.TaiKhoan.HoVaTen : 'Không xác định' %></p>
            <p class="mb-1"><strong>Thể loại:</strong> <%= novel.TheLoai ? novel.TheLoai.tentheloai : 'Không xác định' %></p>
            <p class="mb-1"><strong>Ngày đăng:</strong> <%= new Date(novel.NgayDang).toLocaleString('vi-VN') %></p>
            <p class="mb-2"><strong>Trạng thái hiện tại:</strong>
              <% if (novel.KiemDuyet === 1) { %>
                <span class="badge text-bg-success">Đã duyệt</span>
              <% } else { %>
                <span class="badge text-bg-warning">Chờ duyệt</span>
              <% } %>
            </p>
            <div class="border rounded p-3 bg-light">
              <strong>Tóm tắt:</strong>
              <div class="mt-2"><%- novel.TomTat %></div>
            </div>
          </div>
        </div>

        <form action="/novel/duyet/<%= novel._id %>" method="post" class="mt-4">
          <div class="mb-3">
            <label for="lyDo" class="form-label">Lý do từ chối (nếu có)</label>
            <textarea
              id="lyDo"
              name="lyDo"
              class="form-control"
              rows="3"
              placeholder="Nhập lý do khi từ chối để tác giả biết cách chỉnh sửa"
            ></textarea>
          </div>
          <div class="d-flex gap-2">
            <button class="btn btn-success" type="submit" name="action" value="approve">
              <i class="bi bi-check-circle"></i> Duyệt truyện
            </button>
            <button class="btn btn-danger" type="submit" name="action" value="reject">
              <i class="bi bi-x-circle"></i> Từ chối truyện
            </button>
            <a class="btn btn-outline-secondary" href="/novel">Quay lại</a>
          </div>
        </form>
      </div>
    </div>

    <%- include('includes/footer') %>
  </div>

  <%- include('includes/javascript') %>
</body>
</html>
