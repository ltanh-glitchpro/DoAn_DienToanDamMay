<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <style>
    :root {
      --auth-bg: radial-gradient(circle at 15% 15%, rgba(247, 171, 98, 0.25), transparent 38%),
        radial-gradient(circle at 80% 5%, rgba(63, 123, 197, 0.18), transparent 30%),
        #eef3fb;
      --auth-card-bg: rgba(255, 255, 255, 0.88);
      --auth-card-border: rgba(255, 255, 255, 0.62);
      --auth-title: #b46d21;
      --auth-text: #243447;
      --auth-muted: #65748a;
      --auth-input-bg: #ffffff;
      --auth-input-border: #d4deea;
      --auth-input-focus: #f0a55c;
      --auth-primary: linear-gradient(120deg, #d39b62 0%, #b57935 100%);
      --auth-primary-hover: linear-gradient(120deg, #c98b4d 0%, #a86722 100%);
      --auth-shadow: 0 20px 45px rgba(24, 47, 84, 0.16);
    }

    body.theme-dark {
      --auth-bg: radial-gradient(circle at 14% 12%, rgba(216, 148, 83, 0.24), transparent 34%),
        radial-gradient(circle at 86% 8%, rgba(97, 153, 221, 0.16), transparent 28%),
        #0f1826;
      --auth-card-bg: rgba(19, 30, 45, 0.88);
      --auth-card-border: rgba(72, 98, 130, 0.45);
      --auth-title: #f3c38f;
      --auth-text: #eaf1fb;
      --auth-muted: #a8b6ca;
      --auth-input-bg: rgba(23, 37, 56, 0.9);
      --auth-input-border: #365173;
      --auth-input-focus: #f1b16f;
      --auth-primary: linear-gradient(120deg, #d09c6a 0%, #bc7f42 100%);
      --auth-primary-hover: linear-gradient(120deg, #d9a672 0%, #c0874a 100%);
      --auth-shadow: 0 22px 48px rgba(0, 0, 0, 0.42);
    }

    body {
      font-family: "Be Vietnam Pro", sans-serif;
      background: var(--auth-bg);
      color: var(--auth-text);
      margin: 0;
    }

    .forgot-wrapper {
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 22px 0;
    }

    .forgot-card {
      width: 100%;
      max-width: 460px;
      border: 1px solid var(--auth-card-border);
      border-radius: 20px;
      box-shadow: var(--auth-shadow);
      backdrop-filter: blur(8px);
      background: var(--auth-card-bg);
      overflow: hidden;
    }

    .forgot-header {
      font-size: 2.15rem;
      font-weight: 800;
      letter-spacing: 0.4px;
      color: var(--auth-title);
      text-align: center;
      padding: 30px 0 8px;
    }

    .btn-send {
      background: var(--auth-primary);
      border: none;
      border-radius: 12px;
      min-height: 48px;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .btn-send:hover {
      background: var(--auth-primary-hover);
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(177, 117, 51, 0.28);
    }

    .card-body {
      padding: 18px 24px 24px;
    }

    .form-label {
      font-weight: 600;
    }

    .form-control {
      min-height: 48px;
      border-radius: 12px;
      border: 1px solid var(--auth-input-border);
      background: var(--auth-input-bg);
      color: var(--auth-text);
    }

    .form-control::placeholder {
      color: var(--auth-muted);
    }

    .form-control:focus {
      border-color: var(--auth-input-focus);
      box-shadow: 0 0 0 0.2rem rgba(232, 162, 95, 0.25);
      background: var(--auth-input-bg);
      color: var(--auth-text);
    }

    .back-login {
      display: block;
      text-align: center;
      margin-top: 16px;
      font-size: 1rem;
      font-weight: 500;
    }

    .back-login a {
      text-decoration: none;
      color: #2d6fd4;
    }

    .back-login a:hover {
      text-decoration: underline;
    }

    body.theme-dark .back-login a {
      color: #77b1ff;
    }

    .alert {
      border-radius: 12px;
    }

    @media (max-width: 576px) {
      .forgot-wrapper {
        padding: 10px 0;
        min-height: auto;
      }

      .forgot-card {
        max-width: 100%;
        border-radius: 16px;
      }

      .forgot-header {
        font-size: 1.9rem;
        padding-top: 22px;
      }

      .card-body {
        padding: 16px;
      }
    }
  </style>
</head>

<body>
 <div class="container">
  <%- include('includes/navbar') %>

  <div class="forgot-wrapper">
    <div class="card forgot-card">
      <div class="forgot-header"><%= title %></div>
      <div class="card-body">
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger" role="alert">
            <%= error %>
          </div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success" role="alert">
            <%= success %>
          </div>
        <% } %>

        <form action="/auth/quenmatkhau" method="post" class="needs-validation" novalidate>
          <div class="mb-3">
            <label for="Email" class="form-label">Nhập địa chỉ Email của bạn</label>
            <input type="email" class="form-control" id="Email" name="Email" placeholder="Email" required />
          </div>

          <button type="submit" class="btn btn-send w-100 text-white fw-bold">
            <i class="bi bi-envelope"></i> Gửi mật khẩu mới
          </button>

          <div class="back-login">
            <a href="/auth/dangnhap"><i class="bi bi-arrow-left-circle"></i> Quay lại đăng nhập</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('includes/footer') %>
  </div>
  <%- include('includes/javascript') %>
  <script>
    (() => {
      "use strict";
      const forms = document.querySelectorAll(".needs-validation");
      Array.from(forms).forEach((form) => {
        form.addEventListener(
          "submit",
          (event) => {
            if (!form.checkValidity()) {
              event.preventDefault();
              event.stopPropagation();
            }
            form.classList.add("was-validated");
          },
          false
        );
      });
    })();
  </script>
</body>

</html>
