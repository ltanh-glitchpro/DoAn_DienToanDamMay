# MongoDB (required)
MONGO_URI=mongodb://<username>:<password>@<host>:27017/<database>?ssl=true&authSource=admin

# Mail sender info (recommended)
MAIL_FROM_NAME=KATEE Admin
MAIL_FROM_EMAIL=your_verified_sender@example.com

# SendGrid (recommended for production)
SENDGRID_API_KEY=SG_xxx_your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your_verified_sender@example.com

# SMTP fallback (optional if SendGrid is used)
SMTP_SERVICE=gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password

# Session
SESSION_IDLE_MINUTES=30
SESSION_MAX_HOURS=12
